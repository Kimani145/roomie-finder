rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // =========================================================================
    // CORE SECURITY FUNCTIONS
    // =========================================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAllowedStudentEmail() {
      return request.auth.token.email is string
        && (
          request.auth.token.email.matches('.*@students[.]tukenya[.]ac[.]ke$')
          || request.auth.token.email.matches('.*@tukenya[.]ac[.]ke$')
        );
    }

    function isVerifiedStudent() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && hasAllowedStudentEmail();
    }

    function isOwner(userId) {
      // Removed isVerifiedStudent() so unverified users fetching their own metadata don't trigger permission-denied crashes.
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParticipant(participantsArray) {
      return isVerifiedStudent() && request.auth.uid in participantsArray;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Temporary dev seeder gate. Remove before production hardening.
    // Intentionally broad to verified TUK users, but constrained to seed IDs only.
    function isDevSeeder() {
      return isVerifiedStudent();
    }

    function isSeedUserId(userId) {
      return userId.matches('^seed-user-[0-9]{3}$');
    }

    function isSeedListingId(listingId) {
      return listingId.matches('^listing-seed-user-[0-9]{3}$');
    }

    function validUserDoc(data) {
      return data.keys().hasOnly(['role', 'profileCompleted', 'updatedAt'])
        && data.role in ['HOST', 'SEEKER', 'FLEX'];
    }

    function validProfileDoc(data) {
      return data.keys().hasOnly([
          'uid', 'displayName', 'photoURL', 'role', 'gender', 'age', 'school', 'courseYear',
          'minBudget', 'maxBudget', 'zones', 'preferredRoomType', 'lifestyle', 'dealBreakers',
          'status', 'lastActive', 'createdAt', 'bio', 'bioQuote', 'moveInMonth', 'updatedAt'
        ])
        && data.keys().hasAll([
          'displayName', 'role', 'gender', 'age', 'school', 'courseYear',
          'minBudget', 'maxBudget', 'zones', 'preferredRoomType', 'lifestyle', 'dealBreakers',
          'status', 'lastActive', 'createdAt'
        ])
        && data.role in ['HOST', 'SEEKER', 'FLEX']
        && data.status in ['active', 'inactive', 'paused']
        && data.lifestyle is map
        && data.lifestyle.keys().hasOnly(['sleepTime', 'noiseTolerance', 'guestFrequency', 'cleanlinessLevel', 'studyStyle', 'smoking', 'alcohol'])
        && data.dealBreakers is map
        && data.dealBreakers.keys().hasOnly(['noSmokingRequired', 'noAlcoholRequired', 'mustHaveWiFi', 'femaleOnly', 'maleOnly']);
    }

    function validListingDoc(data) {
      return data.keys().hasOnly([
          'id',
          'hostId',
          'zone',
          'housingType',
          'rentTotal',
          'roommateShare',
          'amenities',
          'photos',
          'houseRules',
          'createdAt',
          'status',
          'interestCount',
          'viewCount',
          'updatedAt'
        ])
        && data.keys().hasAll([
          'id',
          'hostId',
          'zone',
          'housingType',
          'rentTotal',
          'roommateShare',
          'amenities',
          'photos',
          'houseRules',
          'createdAt',
          'status'
        ])
        && data.status in ['active', 'paused', 'filled']
        && data.houseRules is map
        && data.houseRules.keys().hasOnly([
          'smokingAllowed',
          'petsAllowed',
          'guestPolicy'
        ]);
    }

    function canonicalMatchId(userA, userB) {
      return userA < userB ? userA + '_' + userB : userB + '_' + userA;
    }

    function validMatchDoc(data, matchId) {
      return data.keys().hasOnly([
          'id',
          'userA',
          'userB',
          'participants',
          'recipientId',
          'status',
          'compatibilityVersion',
          'createdAt',
          'chatUnlocked'
        ])
        && data.keys().hasAll([
          'id',
          'userA',
          'userB',
          'participants',
          'status',
          'compatibilityVersion',
          'createdAt'
        ])
        && data.userA is string
        && data.userB is string
        && data.userA != data.userB
        && data.id == matchId
        && matchId == canonicalMatchId(data.userA, data.userB)
        && data.participants is list
        && data.participants.size() == 2
        && data.userA in data.participants
        && data.userB in data.participants
        // Allow legacy docs that still carry recipientId while we migrate the app away from it.
        && (!data.keys().hasAny(['recipientId']) || data.recipientId is string)
        && data.status in ['pending', 'matched', 'archived']
        && data.compatibilityVersion is int;
    }

    // =========================================================================
    // USERS
    // =========================================================================
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /users/{userId} {
      // User metadata doc (role/profileCompleted)
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (
          isOwner(userId)
          || (isDevSeeder() && isSeedUserId(userId))
        )
        && validUserDoc(request.resource.data);
      allow update: if ((
          isOwner(userId)
          || (isDevSeeder() && isSeedUserId(userId))
        )
        && validUserDoc(request.resource.data)) || isAdmin();
      allow delete: if false;
    }

    // =========================================================================
    // PROFILES
    // =========================================================================
    match /profiles/{userId} {
      allow read: if true; // Public can see profiles
      allow create: if isOwner(userId) && isVerifiedStudent() && validProfileDoc(request.resource.data);
      allow update: if (isOwner(userId) && isVerifiedStudent() && validProfileDoc(request.resource.data)) || isAdmin();
    }

   	// =========================================================================
    // LISTINGS
    // =========================================================================
    match /listings/{listingId} {
      allow read: if true; // Public can see listings
      
      // CREATION: Must be a verified student, must set yourself as the host, must pass schema validation
      allow create: if isVerifiedStudent() 
        && request.resource.data.hostId == request.auth.uid
        && validListingDoc(request.resource.data);
        
      // UPDATES: Must own the existing listing OR be a verified student incrementing viewCount/interestCount
      allow update: if isVerifiedStudent() 
        && (
          (
            resource.data.hostId == request.auth.uid 
            && request.resource.data.hostId == request.auth.uid
            && validListingDoc(request.resource.data)
          )
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestCount', 'viewCount'])
            && request.resource.data.hostId == resource.data.hostId
            && validListingDoc(request.resource.data)
          )
        );
        
      // DELETION: Must own the existing listing
      allow delete: if isVerifiedStudent() 
        && resource.data.hostId == request.auth.uid;
    }

		// =========================================================================
    // LI	KES
    // =========================================================================
    match /likes/{likeId} {
      // Needed for reverse-like check in likeProfile()
      allow read: if isVerifiedStudent()
        && (
          likeId.matches('^' + request.auth.uid + '_.*') ||
          likeId.matches('.*_' + request.auth.uid + '$') ||
          resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid
        );

      allow create: if isVerifiedStudent()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.keys().hasAll(['fromUid', 'toUid', 'createdAt'])
        && request.resource.data.toUid != request.auth.uid;

      // Immutable interaction record
      allow update, delete: if false;
    }

    // =========================================================================
    // MATCHES
    // =========================================================================
    match /matches/{matchId} {
      // Canonical deterministic ID + participant checks.
      allow read: if isParticipant(resource.data.participants) || isAdmin();

      allow create: if isVerifiedStudent()
        && validMatchDoc(request.resource.data, matchId)
        && (request.auth.uid == request.resource.data.userA
          || request.auth.uid == request.resource.data.userB);

      allow update: if isParticipant(resource.data.participants)
        && validMatchDoc(request.resource.data, matchId)
        && request.resource.data.userA == resource.data.userA
        && request.resource.data.userB == resource.data.userB
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    // =========================================================================
    // CHATS + MESSAGES
    // =========================================================================
    match /chats/{chatId} {
      allow read, update: if isParticipant(resource.data.participants);
      
      // THE GATE: A chat can ONLY be created if a valid Match document exists
      allow create: if isVerifiedStudent()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && exists(/databases/$(database)/documents/matches/$(
             canonicalMatchId(request.resource.data.participants[0], request.resource.data.participants[1])
           ));

      match /messages/{messageId} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow create: if isVerifiedStudent()
          && isParticipant(
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          )
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // =========================================================================
    // ZONES
    // =========================================================================
    match /zones/{zoneId} {
      allow read: if isVerifiedStudent();
      allow write: if isDevSeeder();
    }

    // =========================================================================
    // REPORTS (TRUST & SAFETY)
    // =========================================================================
    match /reports/{reportId} {
      allow create: if isVerifiedStudent() && request.resource.data.keys().hasAll(['reportedUserId', 'reportedBy', 'reason', 'status', 'createdAt']);
      allow read, update: if isAdmin();
      allow delete: if false; // Never delete audit trails
    }

    // =========================================================================
    // NOTIFICATIONS
    // =========================================================================
    match /notifications/{notificationId} {
      // A user can only read and delete their own notifications.
      // (Using recipientId as it matches the frontend's Firestore type structure)
      allow read, delete: if isVerifiedStudent() && resource.data.recipientId == request.auth.uid;
      
      // Any verified student can create or update a notification (e.g., when they 'Like' someone)
      allow create, update: if isVerifiedStudent();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
